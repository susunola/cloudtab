  "cards": [
    { "dot": "cyan",    "title": "Input",  "items": ["Terraform plan.json is the primary source", "HCL direct-read as future fallback", "usage.yml supplies assumptions for usage-based resources (COS / CDN / SCF)"] },
    { "dot": "emerald", "title": "Core",   "items": ["Per-resource Mapper: Extract → Parse", "Pricing engine routes by Product/Action", "Local BoltDB cache eliminates duplicate queries (10 QPS limit)"] },
    { "dot": "rose",    "title": "Pricing","items": ["Direct calls to InquiryPrice* — always in sync with console price", "No self-hosted price DB (unlike Infracost)", "Static tables only for products without an inquiry API"] }
